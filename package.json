{
   "name": "routinely-monorepo",
   "private": true,
   "type": "module",
   "workspaces": [
      "apps/*",
      "packages/*"
   ],
   "engines": {
      "node": "25.9.0"
   },
   "scripts": {
      "dev:frontend": "npm run dev --workspace @repo/frontend",
      "build:frontend": "npm run build --workspace @repo/frontend",
      "dev:backend": "[//TODO: ref to script that runs backend server]",
      "dev:app": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" --names \"FRONTEND,BACKEND\"",
      "lint": "eslint .",
      "typecheck": "npm run typecheck --workspaces --if-present",
      "lint-typecheck": "concurrently \"npm run typecheck\" \"npm run lint\" --success all --prefix-colors \"bgBlue.bold,bgMagenta.bold\" --group --names \"TS-ERROR-CHECK,LINT-ERROR-CHECK\"",
      "format": "prettier --config .prettierrc.json --write \"apps/**/*.{ts,tsx,js,jsx,json,md}\" \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"*.{js,json,md}\""
   },
   "devDependencies": {
      "@eslint/js": "^9.39.4",
      "@types/node": "^24.12.0",
      "concurrently": "^9.2.1",
      "eslint": "^9.39.4",
      "eslint-config-prettier": "^10.1.8",
      "eslint-import-resolver-typescript": "^4.4.4",
      "eslint-plugin-import": "^2.32.0",
      "eslint-plugin-prettier": "^5.5.5",
      "eslint-plugin-react": "^7.37.5",
      "eslint-plugin-react-hooks": "^7.0.1",
      "eslint-plugin-react-refresh": "^0.5.2",
      "eslint-plugin-security": "^4.0.0",
      "eslint-plugin-unused-imports": "^4.4.1",
      "globals": "^17.4.0",
      "prettier": "^3.8.1",
      "typescript": "~5.9.3",
      "typescript-eslint": "^8.57.0"
   }
}
